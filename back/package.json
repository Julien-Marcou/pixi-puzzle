{
  "name": "pixi-puzzle-back",
  "version": "0.0.0",
  "scripts": {
    "build": "npm run clean && npm run assets && esbuild src/index.ts --bundle --minify --platform=node --outfile=dist/pixi-puzzle/index.js",
    "serve": "npm run clean && npm run assets && tsc-watch --onSuccess \"node ./dist/pixi-puzzle/index.js\" --noClear",
    "lint": "eslint \"**/*.ts\"",
    "clean": "rimraf dist/pixi-puzzle/",
    "assets": "cpy .env dist/pixi-puzzle/"
  },
  "private": true,
  "dependencies": {
    "cookie": "^1.1.1",
    "dotenv": "^17.4.2",
    "inversify": "^8.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@eslint/json": "^2.0.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^24.13.2",
    "cpy-cli": "^7.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.4.1",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.16.2",
    "rimraf": "^6.1.3",
    "tsc-watch": "^7.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  }
}
